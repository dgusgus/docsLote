{
  "name": "generador-documentos-masivo",
  "version": "2.0.0",
  "description": "Generador masivo de documentos desde Google Sheets con plantillas Word/Excel",
  "main": "dist/generar.js",
  "type": "module",
  "scripts": {
    "dev": "tsx generar.ts",
    "build": "tsc",
    "start": "node dist/generar.js",
    "clean": "rimraf dist",
    "tipo": "tsx generar.ts --help",
    "qr": "tsx generarQR.ts",
    "qr:todos": "tsx generarQR.ts",
    "qr:ayuda": "tsx generarQR.ts --help"
  },
  "keywords": [
    "documentos",
    "plantillas",
    "google-sheets",
    "word",
    "excel",
    "pdf"
  ],
  "author": "Tu Nombre",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^11.1.0",
    "docxtemplater": "^3.44.0",
    "exceljs": "^4.4.0",
    "googleapis": "^128.0.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1",
    "pdf-lib": "^1.17.1",
    "pizzip": "^3.1.6",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.5",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "rimraf": "^5.0.5",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}